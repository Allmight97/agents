#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf '%s\n' 'Usage:' >&2
  printf '%s\n' '  pass-copy-secret --vault NAME --item TITLE --field FIELD --reason TEXT' >&2
  printf '%s\n' '  pass-copy-secret --uri pass://SHARE/ITEM/FIELD --reason TEXT' >&2
  printf '%s\n' '  pass-copy-secret --vault NAME --item TITLE --totp [FIELD] --reason TEXT' >&2
  printf '%s\n' '  pass-copy-secret --uri pass://SHARE/ITEM[/TOTP_FIELD] --totp --reason TEXT' >&2
  exit 2
}

if ! command -v pbcopy >/dev/null 2>&1; then
  printf '%s\n' 'pbcopy is required for non-disclosing clipboard transfer on macOS.' >&2
  exit 127
fi

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
pass_agent="${script_dir}/pass-agent"
vault=''
item=''
field=''
uri=''
reason=''
mode='field'

while [[ $# -gt 0 ]]; do
  case "$1" in
    --vault)
      [[ $# -ge 2 ]] || usage
      vault=$2
      shift 2
      ;;
    --item)
      [[ $# -ge 2 ]] || usage
      item=$2
      shift 2
      ;;
    --field)
      [[ $# -ge 2 ]] || usage
      field=$2
      shift 2
      ;;
    --uri)
      [[ $# -ge 2 ]] || usage
      uri=$2
      shift 2
      ;;
    --reason)
      [[ $# -ge 2 ]] || usage
      reason=$2
      shift 2
      ;;
    --totp)
      mode='totp'
      if [[ $# -ge 2 && $2 != --* ]]; then
        field=$2
        shift 2
      else
        shift
      fi
      ;;
    *)
      usage
      ;;
  esac
done

[[ -n "$reason" ]] || usage
if [[ -n "$uri" ]]; then
  [[ -z "$vault" && -z "$item" ]] || usage
elif [[ -n "$vault" && -n "$item" ]]; then
  :
else
  usage
fi

if [[ "$mode" == 'field' && -z "$uri" && -z "$field" ]]; then
  usage
fi
if [[ "$mode" == 'field' && -n "$uri" && ! "$uri" =~ ^pass://[^/]+/[^/]+/[^/]+ ]]; then
  printf '%s\n' 'A field copy URI must include vault/share, item, and field components.' >&2
  exit 2
fi
if [[ "$mode" == 'totp' && -n "$uri" && -n "$field" ]]; then
  printf '%s\n' 'With --uri, put the TOTP field in the pass:// URI instead of passing a separate field.' >&2
  exit 2
fi
if [[ "$mode" == 'totp' ]] && ! command -v jq >/dev/null 2>&1; then
  printf '%s\n' 'jq is required to isolate a TOTP code from JSON output.' >&2
  exit 127
fi

export PROTON_PASS_AGENT_REASON="$reason"
if [[ "$mode" == 'totp' ]]; then
  if [[ -n "$uri" ]]; then
    command_args=(item totp "$uri")
  else
    command_args=(item totp --vault-name "$vault" --item-title "$item")
  fi
  if [[ -n "$field" ]]; then
    command_args+=(--field "$field")
  fi
  command_args+=(--output json)
else
  if [[ -n "$uri" ]]; then
    command_args=(item view "$uri")
  else
    command_args=(item view --vault-name "$vault" --item-title "$item" --field "$field")
  fi
fi

if [[ "$mode" == 'totp' ]]; then
  "$pass_agent" "${command_args[@]}" |
    jq -er 'if (.tokens | length) == 1 then .tokens | to_entries[0].value else error("Expected exactly one TOTP field") end' |
    tr -d '\n' |
    pbcopy
else
  secret_value=$("$pass_agent" "${command_args[@]}")
  printf '%s' "$secret_value" | pbcopy
  unset secret_value
fi
printf '%s\n' 'Secret copied to the system clipboard; paste it, then clear the clipboard.'
